# Reddit API (for collect.py via PRAW)
# Create a free app at https://www.reddit.com/prefs/apps (type: "script").
# If these are left blank, collect.py falls back to the public .json endpoints (no auth).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=takemeter-collector/0.1 by u/your_username

# Groq (for prelabel.py and the notebook's zero shot baseline)
GROQ_API_KEY=
